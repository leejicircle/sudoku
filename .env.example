# ──────────────────────────────────────────────
# Database (Supabase PostgreSQL + Prisma ORM)
# ──────────────────────────────────────────────
# Supabase 대시보드 > Settings > Database > Connection string 에서
# Transaction / Session 탭의 URI를 각각 복사하여 붙여넣기
# [YOUR-PASSWORD] 부분만 DB 비밀번호로 교체 (괄호 포함 삭제)
# 비밀번호에 특수문자가 있으면 URL 인코딩 필요 (예: ! → %21)
#
# Transaction 탭 URI → DATABASE_URL (Prisma Client 런타임용, port 6543)
DATABASE_URL=
# Session 탭 URI → DIRECT_URL (Prisma Migrate용, port 5432)
DIRECT_URL=

# ──────────────────────────────────────────────
# Auth.js v5
# ──────────────────────────────────────────────
# `npx auth secret` 또는 `openssl rand -base64 33`으로 생성
AUTH_SECRET=
# Google Cloud Console > OAuth 2.0 Client에서 발급
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Naver Developers > 애플리케이션에서 발급
AUTH_NAVER_ID=
AUTH_NAVER_SECRET=

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
# 로컬: http://localhost:3000 / 프로덕션: 실제 도메인
NEXT_PUBLIC_APP_URL=
