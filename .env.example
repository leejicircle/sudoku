# ──────────────────────────────────────────────
# Database (Supabase PostgreSQL)
# ──────────────────────────────────────────────
# Supabase 대시보드 > Settings > Database > Connection string 에서 확인
# pooling connection (Transaction mode, port 6543) — Prisma Client 런타임용
DATABASE_URL=
# direct connection (port 5432) — Prisma Migrate용
DIRECT_URL=

# ──────────────────────────────────────────────
# Auth.js v5
# ──────────────────────────────────────────────
# `npx auth secret` 또는 `openssl rand -base64 33`으로 생성
AUTH_SECRET=
# Google Cloud Console > OAuth 2.0 Client에서 발급
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Naver Developers > 애플리케이션에서 발급
AUTH_NAVER_ID=
AUTH_NAVER_SECRET=

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
# 로컬: http://localhost:3000 / 프로덕션: 실제 도메인
NEXT_PUBLIC_APP_URL=
